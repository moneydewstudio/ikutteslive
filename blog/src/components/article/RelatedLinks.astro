---
// TEAM_033: RelatedLinks - Design System Refactor
// Uses unified Card component
import Card from '../global/Card.astro';

type Item = {
  href: string;
  title: string;
  updatedAt?: string | null;
};

type Props = {
  title: string;
  items: Item[];
};

const { title, items } = Astro.props;
---

{items.length ? (
  <section class="bg-white rounded-[28px] border-2 border-stone-800 p-6 shadow-[0px_2px_0px_0px_rgba(41,37,36,1)]">
    <h2 class="text-xl font-bold text-stone-800 mb-5">{title}</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {items.map((item) => (
        <Card
          variant="default"
          size="sm"
          href={item.href}
          title={item.title}
          updatedAt={item.updatedAt}
        />
      ))}
    </div>
  </section>
) : null}
