---
// TEAM_033: Formation table - Design System Refactor
// Clean data table with subtle styling
import type { FormationEntry } from '../../lib/blogContent';

interface Props {
  formations: FormationEntry[];
  caption?: string;
}

const { formations, caption } = Astro.props;

const formatQuota = (quota: number): string => quota.toLocaleString('id-ID');
---

<div class="bg-white rounded-[28px] border-2 border-stone-800 overflow-hidden shadow-[0px_2px_0px_0px_rgba(41,37,36,1)]">
  {caption && (
    <div class="bg-stone-100 border-b-2 border-stone-800 px-4 py-3">
      <p class="text-sm font-semibold text-stone-700">{caption}</p>
    </div>
  )}

  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b-2 border-stone-800 bg-stone-100">
          <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-stone-700">
            Instansi
          </th>
          <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-stone-700">
            Jabatan
          </th>
          <th class="px-4 py-3 text-right text-xs font-bold uppercase tracking-wider text-stone-700">
            Kuota
          </th>
          <th class="px-4 py-3 text-left text-xs font-bold uppercase tracking-wider text-stone-700">
            Pendidikan
          </th>
        </tr>
      </thead>
      <tbody>
        {formations.map((f, idx) => (
          <tr class={`border-b border-stone-200 last:border-b-0 ${idx % 2 === 1 ? 'bg-stone-50' : 'bg-white'}`}>
            <td class="px-4 py-3 text-sm font-medium text-stone-800">
              {f.institution}
            </td>
            <td class="px-4 py-3 text-sm text-stone-600">
              {f.position}
              {f.additional_requirements && (
                <p class="text-xs text-stone-400 mt-1">{f.additional_requirements}</p>
              )}
            </td>
            <td class="px-4 py-3 text-right">
              <span class="text-sm font-bold text-stone-800 tabular-nums">
                {formatQuota(f.quota)}
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-stone-600">
              {f.education_required}
              {f.major_required && f.major_required !== 'Semua jurusan' && (
                <p class="text-xs text-stone-400">{f.major_required}</p>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
