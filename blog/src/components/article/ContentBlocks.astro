---
// TEAM_033: ContentBlocks - Design System Refactor
// Proper typography hierarchy, spacing, and clean card styling
import type { ContentBlock } from '../../lib/blogContent';
import Card from '../global/Card.astro';

type Props = {
  blocks: ContentBlock[];
};

const { blocks } = Astro.props;
---

<div class="space-y-6">
  {blocks.map((block, idx) => {
    if (block.type === 'paragraph') {
      const rendered = (
        <p class="text-base leading-relaxed text-stone-700">
          {block.text}
        </p>
      );
      // Insert Ezoic mid-content ad after the first paragraph only
      if (idx === 0) {
        return (
          <>
            {rendered}
            <div id="ezoic-pub-ad-placeholder-201"></div>
            <script is:inline>
              if (typeof window !== 'undefined' && window.ezstandalone && window.ezstandalone.cmd) {
                window.ezstandalone.cmd.push(() => window.ezstandalone.showAds(201));
              }
            </script>
          </>
        );
      }
      return rendered;
    }
    if (block.type === 'heading') {
      return block.level === 2 ? (
        <h2 class="mt-8 mb-4 text-2xl font-bold text-stone-800 leading-tight">
          {block.text}
        </h2>
      ) : (
        <h3 class="mt-6 mb-3 text-xl font-semibold text-stone-800 leading-snug">
          {block.text}
        </h3>
      );
    }
    if (block.type === 'list') {
      return block.ordered ? (
        <ol class="list-decimal space-y-2 pl-6 text-base text-stone-600">
          {block.items.map((item) => (
            <li class="leading-relaxed pl-2">{item}</li>
          ))}
        </ol>
      ) : (
        <ul class="list-disc space-y-2 pl-6 text-base text-stone-600">
          {block.items.map((item) => (
            <li class="leading-relaxed pl-2">{item}</li>
          ))}
        </ul>
      );
    }
    if (block.type === 'cta') {
      return (
        <Card
          variant="cream"
          size="lg"
          icon="🚀"
          eyebrow="Ayo Mulai"
          title="Siap untuk latihan?"
          description="Akses ribuan soal latihan CPNS dengan pembahasan lengkap. Gratis!"
          href="https://ikuttes.my.id/"
          buttonLabel="Mulai Daily Quiz"
          external
        />
      );
    }
    if (block.type === 'question_preview') {
      return (
        <Card
          variant="outline"
          size="md"
          icon="📝"
          eyebrow="Contoh Soal"
          title={`Kode: ${block.questionId}`}
          description="Latihan soal ini tersedia di Daily Quiz. Kerjakan untuk melihat pembahasan lengkap."
          href="https://ikuttes.my.id/"
          buttonLabel="Kerjakan di Daily Quiz"
          external
        />
      );
    }
    return null;
  })}
</div>
