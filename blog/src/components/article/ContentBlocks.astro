---
// TEAM_010: render programmatic content blocks without Markdown parsing
import type { ContentBlock } from '../../lib/blogContent';
import CtaCard from '../global/CtaCard.astro';

type Props = {
  blocks: ContentBlock[];
};

const { blocks } = Astro.props;
---

<div class="space-y-5">
  {blocks.map((block) => {
    if (block.type === 'paragraph') {
      return <p class="leading-relaxed text-black/90">{block.text}</p>;
    }
    if (block.type === 'heading') {
      return block.level === 2 ? (
        <h2 class="mt-8 text-xl font-extrabold">{block.text}</h2>
      ) : (
        <h3 class="mt-6 text-lg font-extrabold">{block.text}</h3>
      );
    }
    if (block.type === 'list') {
      return block.ordered ? (
        <ol class="list-decimal space-y-2 pl-5">
          {block.items.map((item) => (
            <li class="leading-relaxed">{item}</li>
          ))}
        </ol>
      ) : (
        <ul class="list-disc space-y-2 pl-5">
          {block.items.map((item) => (
            <li class="leading-relaxed">{item}</li>
          ))}
        </ul>
      );
    }
    if (block.type === 'cta') {
      return <CtaCard style={block.style} />;
    }
    if (block.type === 'question_preview') {
      return (
        <div class="border-3 border-black bg-white p-4 shadow-neo-sm">
          <div class="text-xs font-black uppercase tracking-wider">Contoh soal</div>
          <div class="mt-2 text-sm text-black/80">
            Kode soal: <span class="font-mono font-semibold">{block.questionId}</span>
          </div>
          <div class="mt-3">
            <a
              class="inline-flex items-center justify-center border-3 border-black bg-brand-lime px-4 py-2 text-sm font-extrabold shadow-neo-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none"
              href="https://ikuttes.my.id/"
            >
              Kerjakan di Daily Quiz
            </a>
          </div>
        </div>
      );
    }
    return null;
  })}
</div>
