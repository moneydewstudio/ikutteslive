---
// TEAM_033: ProgrammaticArticle - Design System Refactor
// Clean article layout with proper spacing and typography

import ArticleLayout from '../../layouts/ArticleLayout.astro';
import Shell from '../global/Shell.astro';
import ContentBlocks from './ContentBlocks.astro';
import FormationsTable from './FormationsTable.astro';
import RelatedLinks from './RelatedLinks.astro';
import Card from '../global/Card.astro';

import type { ProgrammaticPageRecord, HubRecord } from '../../lib/blogContent';
import type { SeoConfig } from '../../lib/utils/seo';

interface Props {
  page: ProgrammaticPageRecord;
  seo: SeoConfig;
  schema: unknown[];
  relatedSameHub: Array<{ href: string; title: string; updatedAt: string | null }>;
  alsoRead?: Array<{ href: string; title: string; updatedAt: string | null }>;
  hubRecord?: HubRecord | null;
  category?: string;
  showFormations?: boolean;
}

const {
  page,
  seo,
  schema,
  relatedSameHub,
  alsoRead = [],
  hubRecord = null,
  category = '',
  showFormations = false
} = Astro.props;

const formatQuota = (quota: number): string => quota.toLocaleString('id-ID');

const totalQuota = showFormations && page.formationsData
  ? page.formationsData.reduce((sum, f) => sum + f.quota, 0)
  : 0;

// Hub badge styling - Neo-playful
const hubBadgeStyles: Record<string, string> = {
  'tiu': 'bg-indigo-100 text-indigo-900 border-indigo-900',
  'twk': 'bg-orange-100 text-orange-900 border-orange-900',
  'tkp': 'bg-emerald-100 text-emerald-900 border-emerald-900',
  'provinsi': 'bg-stone-100 text-stone-700 border-stone-800',
  'kota': 'bg-stone-100 text-stone-700 border-stone-800',
  'institusi': 'bg-stone-100 text-stone-700 border-stone-800',
  'pendidikan': 'bg-stone-100 text-stone-700 border-stone-800',
};

const hubBadge = category
  ? `${hubRecord?.title ?? category} • Formasi CPNS 2024`
  : (page?.hub ?? '').toUpperCase();

const hubStyle = category
  ? hubBadgeStyles[category] || 'bg-bg-subtle text-text-secondary'
  : hubBadgeStyles[page?.hub ?? ''] || 'bg-bg-subtle text-text-secondary';

// Related sections titles
const sameHubTitle = category ? 'Lihat Juga' : 'Artikel terkait';
const alsoReadTitle = 'Baca juga';
---

<ArticleLayout
  title={seo.title}
  description={seo.description ?? null}
  canonical={seo.canonical}
  noindex={seo.noindex}
  schema={schema}
>
  <Shell>
    <article class="space-y-8">
      {/* Article Header - Neo-playful */}
      <header class="bg-white rounded-[28px] border-2 border-stone-800 p-6 md:p-8 shadow-[0px_2px_0px_0px_rgba(41,37,36,1)]">
        <div class={`inline-block px-3 py-1 rounded-lg text-xs font-semibold uppercase tracking-wider mb-4 border-2 ${hubStyle}`}>
          {hubBadge}
        </div>
        <h1 class="text-3xl font-bold text-stone-800 mb-4">{page.h1}</h1>
        {seo.description && (
          <p class="text-lg text-stone-600 leading-relaxed">{seo.description}</p>
        )}
      </header>

      {/* Main Content - Neo-playful */}
      <div class="bg-white rounded-[28px] border-2 border-stone-800 p-6 md:p-8 shadow-[0px_2px_0px_0px_rgba(41,37,36,1)]">
        <ContentBlocks blocks={page.contentBlocks} />
      </div>

      {/* Formation Table Section (conditional) */}
      {showFormations && page.formationsData && page.formationsData.length > 0 && (
        <section class="space-y-4">
          <h2 class="text-2xl font-bold text-stone-800 leading-tight">Daftar Formasi dan Kuota</h2>
          <FormationsTable
            formations={page.formationsData}
            caption={`Total ${formatQuota(totalQuota)} kuota tersedia`}
          />
        </section>
      )}

      {/* Related Articles */}
      <RelatedLinks title={sameHubTitle} items={relatedSameHub} />

      {alsoRead.length > 0 && (
        <RelatedLinks title={alsoReadTitle} items={alsoRead} />
      )}

      {/* CTA Card - Warm Cream */}
      <Card
        variant="cream"
        size="lg"
        href="https://ikuttes.my.id/"
        icon="🚀"
        eyebrow="Ayo Mulai"
        title="Siap untuk latihan?"
        description="Akses ribuan soal latihan CPNS dengan pembahasan lengkap. Mulai dari TIU, TWK, dan TKP."
        buttonLabel="Mulai Daily Quiz →"
        external
      />
    </article>
  </Shell>
</ArticleLayout>
