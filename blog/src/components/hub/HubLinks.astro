---
// TEAM_033: HubLinks - Design System Refactor
// Uses unified Card component
import Card from '../global/Card.astro';

type Item = {
  href: string;
  title: string;
  updatedAt?: string | null;
};

type Props = {
  items: Item[];
};

const { items } = Astro.props;
---

<div class="grid gap-4 sm:grid-cols-2">
  {items.map((item) => (
    <Card
      variant="default"
      size="md"
      href={item.href}
      title={item.title}
      updatedAt={item.updatedAt}
    />
  ))}
</div>
