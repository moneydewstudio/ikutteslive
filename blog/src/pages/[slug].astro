---
// TEAM_032: programmatic page (flat route /:slug) - refactored to use ProgrammaticArticle
import ArticleLayout from '../layouts/ArticleLayout.astro';
import Shell from '../components/global/Shell.astro';
import HubLinks from '../components/hub/HubLinks.astro';
import CtaCard from '../components/global/CtaCard.astro';
import ProgrammaticArticle from '../components/article/ProgrammaticArticle.astro';

import { getRuntimeEnv } from '../lib/utils/runtime';
import { getDb } from '../lib/db/client';
import {
  getProgrammaticPageBySlug,
  getRecentProgrammaticPages,
  getRelatedProgrammaticPagesForHub,
  getHubBySlug,
  getRecentProgrammaticPagesForHub,
} from '../lib/db/queries';

import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildCollectionPageSchema,
  buildFaqSchema,
  buildOrganizationSchema,
  buildSiteSchema,
  buildWebPageSchema,
  normalizeSeoConfig,
  shouldNoIndex,
} from '../lib/utils/seo';

import { extractFaqPairs, getBlocksWordCount, injectCtaBlock } from '../lib/blogContent';
import { setCacheControl, PROGRAMMATIC_CACHE_CONTROL, NOT_FOUND_CACHE_CONTROL } from '../lib/utils/cache';
import { HUB_SLUGS } from '../lib/constants';
import type { ProgrammaticPageRecord } from '../lib/blogContent';

const slug = Astro.params.slug;

if (!slug) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
}

const env = getRuntimeEnv(Astro.locals);
const db = getDb(env);
const isHub = Boolean(slug && HUB_SLUGS.includes(slug as (typeof HUB_SLUGS)[number]));
const hubRecord = isHub && slug ? await getHubBySlug(db, slug) : null;
const FORMASI_HUBS = ['provinsi', 'kota', 'institusi', 'pendidikan'];
const page = !isHub && slug ? await getProgrammaticPageBySlug(db, slug) : null;

// Exclude formasi pages from [slug].astro - they must use nested URLs
const isFormasiPage = page && FORMASI_HUBS.includes(page.hub);

if (isHub && !hubRecord) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
}

if (!isHub && (!page || isFormasiPage)) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
}

// Set normal caching only for successful responses
if ((isHub && hubRecord) || (!isHub && page && !isFormasiPage)) {
  setCacheControl(Astro.response.headers, PROGRAMMATIC_CACHE_CONTROL);
}

const canonicalPath = isHub
  ? `/${hubRecord?.slug ?? slug ?? ''}`
  : page
    ? `/${page.slug}`
    : Astro.url.pathname;

const processedPage: ProgrammaticPageRecord | null = page 
  ? { ...page, contentBlocks: injectCtaBlock(page.contentBlocks, page.intent) }
  : null;
const wordCount = processedPage ? getBlocksWordCount(processedPage.contentBlocks) : 0;

const seo = isHub
  ? normalizeSeoConfig({
      title: hubRecord?.title ?? 'Hub',
      description: hubRecord?.metaDescription ?? null,
      canonicalPath,
      noindex: false,
      ogType: 'website',
    })
  : page
    ? normalizeSeoConfig({
        title: page.title,
        description: page.metaDescription,
        canonicalPath,
        noindex: shouldNoIndex(wordCount, page.metaDescription),
        ogType: 'article',
      })
    : normalizeSeoConfig({
        title: 'Artikel',
        description: null,
        canonicalPath,
        noindex: true,
        ogType: 'article',
      });

const faqs = processedPage ? extractFaqPairs(processedPage.contentBlocks) : [];

const schema = isHub
  ? [
      buildSiteSchema(),
      buildOrganizationSchema(),
      buildBreadcrumbSchema([
        { name: 'Ikuttes Blog', path: '/' },
        { name: (hubRecord?.slug ?? slug ?? '').toUpperCase(), path: canonicalPath },
      ]),
      buildCollectionPageSchema({
        title: seo.title,
        description: seo.description ?? null,
        path: canonicalPath,
      }),
    ].filter(Boolean)
  : [
      buildSiteSchema(),
      buildOrganizationSchema(),
      buildBreadcrumbSchema([
        { name: 'Ikuttes Blog', path: '/' },
        { name: (page?.hub ?? '').toUpperCase(), path: `/${page?.hub ?? ''}` },
        { name: page?.h1 ?? slug ?? '', path: canonicalPath },
      ]),
      buildWebPageSchema({ title: seo.title, description: seo.description ?? null, path: canonicalPath }),
      buildArticleSchema({
        title: seo.title,
        description: seo.description ?? null,
        path: canonicalPath,
        updatedAt: page?.updatedAt ?? null,
      }),
    ].filter(Boolean);

const faqSchema = !isHub ? buildFaqSchema(faqs) : null;
if (faqSchema) schema.push(faqSchema);

const relatedSameHubRows = page
  ? await getRelatedProgrammaticPagesForHub(db, page.hub, page.slug, 6)
  : [];

const relatedSameHub = relatedSameHubRows.map((row) => ({
  href: `/blog/${row.slug}`,
  title: row.title,
  updatedAt: row.updatedAt ? new Date(row.updatedAt).toISOString().slice(0, 10) : null,
}));

const alsoReadRows = page ? await getRecentProgrammaticPages(db, page.id, 6) : [];
const alsoRead = alsoReadRows
  .filter((row) => row.hub !== page?.hub)
  .slice(0, 4)
  .map((row) => ({
    href: `/blog/${row.slug}`,
    title: row.title,
    updatedAt: row.updatedAt ? new Date(row.updatedAt).toISOString().slice(0, 10) : null,
  }));

const hubItemsRows = hubRecord ? await getRecentProgrammaticPagesForHub(db, hubRecord.slug, 12) : [];
const hubItems = hubItemsRows.map((row) => ({
  href: `/blog/${row.slug}`,
  title: row.title,
  updatedAt: row.updatedAt ? new Date(row.updatedAt).toISOString().slice(0, 10) : null,
}));
---

{isHub ? (
  <ArticleLayout
    title={seo.title}
    description={seo.description ?? null}
    canonical={seo.canonical}
    noindex={seo.noindex}
    schema={schema}
  >
    <Shell>
      <div class="grid gap-8">
        <section class="border-3 border-black bg-white p-6 shadow-neo">
          <h1 class="text-2xl font-extrabold">{seo.title}</h1>
          {seo.description ? <p class="mt-3 text-sm text-black/80">{seo.description}</p> : null}
        </section>

        <CtaCard style="hard" />

        <section>
          <h2 class="text-lg font-extrabold">Artikel terbaru</h2>
          <p class="mt-2 text-sm text-black/70">Pilih materi lalu langsung latihan di Daily Quiz.</p>
          <div class="mt-5">
            <HubLinks items={hubItems} />
          </div>
        </section>
      </div>
    </Shell>
  </ArticleLayout>
) : processedPage ? (
  <ProgrammaticArticle
    page={processedPage}
    seo={seo}
    schema={schema}
    relatedSameHub={relatedSameHub}
    alsoRead={alsoRead}
    showFormations={false}
  />
) : null}
