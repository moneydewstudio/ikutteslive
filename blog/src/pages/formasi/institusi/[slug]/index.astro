---
// TEAM_030: Institution formasi page (/blog/formasi/institusi/:slug/)
import ArticleLayout from '../../../../layouts/ArticleLayout.astro';
import Shell from '../../../../components/global/Shell.astro';
import ContentBlocks from '../../../../components/article/ContentBlocks.astro';
import CtaCard from '../../../../components/global/CtaCard.astro';

import { getRuntimeEnv } from '../../../../lib/utils/runtime';
import { getDb } from '../../../../lib/db/client';
import {
  getFormasiPageBySlug,
  getFormasiProvincesByInstitution,
} from '../../../../lib/db/queries';

import {
  buildSiteSchema,
  buildOrganizationSchema,
  buildBreadcrumbSchema,
  buildWebPageSchema,
  normalizeSeoConfig,
} from '../../../../lib/utils/seo';

import { injectCtaBlock } from '../../../../lib/blogContent';
import { setCacheControl, PROGRAMMATIC_CACHE_CONTROL, NOT_FOUND_CACHE_CONTROL } from '../../../../lib/utils/cache';

const { slug } = Astro.params;

if (!slug) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
  return new Response('Not found', { status: 404 });
}

const env = getRuntimeEnv(Astro.locals);
const db = getDb(env);

// Fetch institution page
const page = await getFormasiPageBySlug(db, slug);

if (!page || page.pageType !== 'institution') {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
  return new Response('Not found', { status: 404 });
}

setCacheControl(Astro.response.headers, PROGRAMMATIC_CACHE_CONTROL);

const canonicalPath = `/formasi/institusi/${slug}`;

const blocks = injectCtaBlock(page.contentBlocks, 'practice');

const seo = normalizeSeoConfig({
  title: page.title,
  description: page.metaDescription,
  canonicalPath,
  noindex: false,
  ogType: 'article',
});

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Formasi CPNS', path: '/formasi' },
    { name: page.institution ?? slug, path: canonicalPath },
  ]),
  buildWebPageSchema({ title: seo.title, description: seo.description ?? null, path: canonicalPath }),
].filter(Boolean);

// Fetch provinces where this institution has openings
const provinces = await getFormasiProvincesByInstitution(db, slug);
---

<ArticleLayout
  title={seo.title}
  description={seo.description ?? null}
  canonical={seo.canonical}
  noindex={seo.noindex}
  schema={schema}
>
  <Shell>
    <article class="grid gap-6">
      <header class="border-3 border-black bg-white p-6 shadow-neo">
        <div class="text-xs font-black uppercase tracking-wider text-brand-lime">FORMASI INSTANSI</div>
        <h1 class="mt-2 text-2xl font-extrabold">{page.title}</h1>
        {seo.description ? <p class="mt-3 text-sm text-black/80">{seo.description}</p> : null}
        {page.hasPlaceholderData ? (
          <p class="mt-2 text-xs text-yellow-600 bg-yellow-50 border border-yellow-200 rounded px-2 py-1 inline-block">
            Data formasi akan segera diperbarui dengan informasi terkini.
          </p>
        ) : null}
      </header>

      <ContentBlocks blocks={blocks} />

      {provinces.length > 0 && (
        <section class="border-3 border-black bg-white p-6 shadow-neo-sm">
          <h2 class="text-lg font-extrabold">Provinsi dengan Formasi {page.institution}</h2>
          <p class="mt-2 text-sm text-black/70">Cek formasi di provinsi berikut:</p>
          <div class="mt-4 grid gap-2 sm:grid-cols-2">
            {provinces.map((prov) => (
              <a
                href={`/blog/formasi/provinsi/${prov.provinceSlug}`}
                class="flex items-center justify-between border-2 border-black bg-white px-4 py-3 shadow-neo-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none hover:bg-brand-lime/10 transition-all"
              >
                <span class="font-bold">{prov.province}</span>
                <span class="text-sm text-black/60">Lihat →</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <CtaCard style="hard" />

      <div class="grid gap-4 sm:grid-cols-2">
        <a
          href="/blog/formasi"
          class="border-3 border-black bg-white p-4 shadow-neo-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none hover:bg-brand-lime/10 transition-all text-center font-bold"
        >
          ← Kembali ke Formasi
        </a>
      </div>
    </article>
  </Shell>
</ArticleLayout>
