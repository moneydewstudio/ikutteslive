---
// TEAM_033: Formasi CPNS hub page - Design System Refactor
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import Shell from '../../components/global/Shell.astro';
import Card from '../../components/global/Card.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

import { getRuntimeEnv } from '../../lib/utils/runtime';
import { getDb } from '../../lib/db/client';
import { getHubCategoriesWithCounts } from '../../lib/db/queries';

import {
  buildSiteSchema,
  buildOrganizationSchema,
  buildBreadcrumbSchema,
  buildWebPageSchema,
  normalizeSeoConfig,
} from '../../lib/utils/seo';

import { setCacheControl, PROGRAMMATIC_CACHE_CONTROL } from '../../lib/utils/cache';

const env = getRuntimeEnv(Astro.locals);
const db = getDb(env);

setCacheControl(Astro.response.headers, PROGRAMMATIC_CACHE_CONTROL);

const title = 'Formasi CPNS 2024 — Info Lengkap Provinsi, Instansi & Persyaratan';
const description = 'Info lengkap formasi CPNS seluruh Indonesia: provinsi, kota, instansi, dan persyaratan. Data terbaru dan cara daftar.';
const canonicalPath = '/formasi';

const seo = normalizeSeoConfig({
  title,
  description,
  canonicalPath,
  noindex: false,
  ogType: 'website',
});

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Ikuttes Blog', path: '/' },
    { name: 'Formasi CPNS', path: canonicalPath },
  ]),
  buildWebPageSchema({ title, description, path: canonicalPath }),
].filter(Boolean);

// Category display config with playful colors
const categoryConfig: Record<string, { title: string; description: string; variant: 'lavender' | 'peach' | 'mint' | 'sky' | 'outline' }> = {
  provinsi: { title: 'Formasi per Provinsi', description: 'Pilih provinsi untuk melihat formasi lengkap', variant: 'lavender' },
  kota: { title: 'Formasi per Kota', description: 'Cari formasi berdasarkan kota/kabupaten', variant: 'peach' },
  institusi: { title: 'Formasi per Instansi', description: 'Cek formasi instansi favorit Anda', variant: 'mint' },
  pendidikan: { title: 'Formasi by Pendidikan', description: 'Cek formasi sesuai jenjang pendidikan', variant: 'sky' },
};

// Fetch hub categories with counts
const categories = await getHubCategoriesWithCounts(db);
---

<ArticleLayout
  title={seo.title}
  description={seo.description ?? null}
  canonical={seo.canonical}
  noindex={seo.noindex}
  schema={schema}
>
  <Shell>
    <Breadcrumbs items={[
      { name: 'Ikuttes Blog', path: '/' },
      { name: 'Formasi CPNS', path: canonicalPath },
    ]} />

    <article class="space-y-8">
      {/* Header - Neo-playful */}
      <header class="bg-white rounded-[28px] border-2 border-stone-800 p-6 md:p-8 shadow-[0px_2px_0px_0px_rgba(41,37,36,1)]">
        <div class="inline-block px-3 py-1 rounded-lg bg-indigo-100 text-xs font-medium uppercase tracking-wider text-indigo-900 border-2 border-indigo-900 mb-4">
          Pusat Informasi
        </div>
        <h1 class="text-3xl font-bold text-stone-800 mb-4 leading-tight">Formasi CPNS 2024</h1>
        <p class="text-lg text-stone-600 leading-relaxed">
          Informasi lengkap formasi CPNS seluruh Indonesia. Cek formasi berdasarkan provinsi, instansi, atau tingkat pendidikan Anda.
        </p>
      </header>

      {/* Category Cards - Playful Pastel */}
      <div class="grid gap-4 sm:grid-cols-2">
        {categories.map((cat) => {
          const config = categoryConfig[cat.hub] ?? { title: cat.title, description: '', variant: 'outline' };
          const icons = {
            provinsi: '🗺️',
            kota: '🏙️',
            institusi: '🏛️',
            pendidikan: '🎓'
          };
          return (
            <Card
              variant={config.variant}
              size="lg"
              href={`/blog/formasi/${cat.hub}`}
              icon={icons[cat.hub] || '📋'}
              title={config.title}
              description={`${config.description}. ${cat.count} halaman tersedia.`}
              buttonLabel={`Lihat ${cat.count} Halaman →`}
            />
          );
        })}
      </div>

      {/* SKD CTA - Neo-playful */}
      <section class="bg-indigo-50 rounded-[28px] p-6 md:p-8 border-2 border-indigo-200">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
          <div>
            <h2 class="text-xl font-bold text-stone-800 mb-2 leading-snug">Siap Hadapi SKD?</h2>
            <p class="text-base text-stone-600 leading-relaxed">
              Setelah lolos administrasi, ujian SKD adalah tahapan berikutnya. Mayoritas peserta gagal di tahap ini. Persiapkan diri dari sekarang!
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://ikuttes.my.id/?view=DRILLS"
              class="inline-flex items-center justify-center px-5 py-2.5 bg-white text-stone-700 font-medium rounded-lg border-2 border-stone-800 shadow-[0px_2px_0px_0px_rgba(41,37,36,1)] hover:translate-y-[2px] hover:shadow-none transition-all duration-100"
            >
              Latihan Soal Harian
            </a>
            <a
              href="https://ikuttes.my.id/?view=TRYOUT"
              class="inline-flex items-center justify-center px-5 py-2.5 bg-indigo-500 text-white font-medium rounded-lg border-2 border-indigo-900 shadow-[0px_2px_0px_0px_rgba(49,46,129,1)] hover:translate-y-[2px] hover:shadow-none transition-all duration-100"
            >
              Simulasi CAT
            </a>
          </div>
        </div>
      </section>

      {/* CTA Card - Warm Cream */}
      <Card
        variant="cream"
        size="lg"
        href="https://ikuttes.my.id/"
        icon="🎯"
        eyebrow="Selanjutnya"
        title="Persiapkan Diri untuk CPNS"
        description="Setelah cek formasi, mulai latihan soal sekarang. Daily Quiz gratis dengan pembahasan lengkap."
        buttonLabel="Mulai Latihan →"
        external
      />
    </article>
  </Shell>
</ArticleLayout>
