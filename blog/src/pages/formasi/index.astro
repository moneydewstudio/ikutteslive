---
// TEAM_031: Formasi CPNS hub page (/blog/formasi/) - Hub-based architecture
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import Shell from '../../components/global/Shell.astro';
import CtaCard from '../../components/global/CtaCard.astro';

import { getRuntimeEnv } from '../../lib/utils/runtime';
import { getDb } from '../../lib/db/client';
import { getHubCategoriesWithCounts } from '../../lib/db/queries';

import {
  buildSiteSchema,
  buildOrganizationSchema,
  buildBreadcrumbSchema,
  buildWebPageSchema,
  normalizeSeoConfig,
} from '../../lib/utils/seo';

import { setCacheControl, PROGRAMMATIC_CACHE_CONTROL } from '../../lib/utils/cache';

const env = getRuntimeEnv(Astro.locals);
const db = getDb(env);

setCacheControl(Astro.response.headers, PROGRAMMATIC_CACHE_CONTROL);

const title = 'Formasi CPNS 2024 — Info Lengkap Provinsi, Instansi & Persyaratan';
const description = 'Info lengkap formasi CPNS seluruh Indonesia: provinsi, kota, instansi, dan persyaratan. Data terbaru dan cara daftar.';
const canonicalPath = '/formasi';

const seo = normalizeSeoConfig({
  title,
  description,
  canonicalPath,
  noindex: false,
  ogType: 'website',
});

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Ikuttes Blog', path: '/' },
    { name: 'Formasi CPNS', path: canonicalPath },
  ]),
  buildWebPageSchema({ title, description, path: canonicalPath }),
].filter(Boolean);

// Category display config
const categoryConfig: Record<string, { title: string; description: string; color: string }> = {
  provinsi: { title: 'Formasi per Provinsi', description: 'Pilih provinsi untuk melihat formasi lengkap', color: 'bg-brand-lime' },
  kota: { title: 'Formasi per Kota', description: 'Cari formasi berdasarkan kota/kabupaten', color: 'bg-brand-pink' },
  institusi: { title: 'Formasi per Instansi', description: 'Cek formasi instansi favorit Anda', color: 'bg-brand-purple' },
  pendidikan: { title: 'Formasi by Pendidikan', description: 'Cek formasi sesuai jenjang pendidikan', color: 'bg-brand-blue' },
};

// Fetch hub categories with counts
const categories = await getHubCategoriesWithCounts(db);
---

<ArticleLayout
  title={seo.title}
  description={seo.description ?? null}
  canonical={seo.canonical}
  noindex={seo.noindex}
  schema={schema}
>
  <Shell>
    <article class="grid gap-8">
      <header class="border-3 border-black bg-white p-6 shadow-neo">
        <div class="text-xs font-black uppercase tracking-wider text-brand-lime">PUSAT INFORMASI</div>
        <h1 class="mt-2 text-2xl font-extrabold">Formasi CPNS 2024</h1>
        <p class="mt-3 text-sm text-black/80">
          Informasi lengkap formasi CPNS seluruh Indonesia. Cek formasi berdasarkan provinsi, 
          instansi, atau tingkat pendidikan Anda.
        </p>
      </header>

      <CtaCard style="hard" />

      {/* Hub Categories */}
      {categories.map((cat) => {
        const config = categoryConfig[cat.hub] ?? { title: cat.title, description: '', color: 'bg-brand-lime' };
        return (
          <section class={`border-3 border-black bg-white p-6 shadow-neo-sm ${config.color}20`}>
            <h2 class="text-lg font-extrabold">{config.title}</h2>
            <p class="mt-2 text-sm text-black/70">{config.description}:</p>
            <div class="mt-4 flex items-center gap-4">
              <span class="text-2xl font-black">{cat.count}</span>
              <span class="text-sm text-black/60">halaman tersedia</span>
            </div>
            <div class="mt-4">
              <a
                href={`/blog/formasi/${cat.hub}`}
                class={`inline-flex items-center justify-center border-3 border-black ${config.color} px-4 py-2 text-sm font-extrabold shadow-neo-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none`}
              >
                Lihat Semua {config.title}
              </a>
            </div>
          </section>
        );
      })}

      {/* SKD CTA */}
      <section class="border-3 border-black bg-brand-lime p-6 shadow-neo">
        <h2 class="text-lg font-extrabold">Siap Hadapi SKD?</h2>
        <p class="mt-2 text-sm text-black/80">
          Setelah lolos administrasi, ujian SKD (Seleksi Kompetensi Dasar) adalah tahapan berikutnya. 
          Mayoritas peserta gagal di tahap ini. Persiapkan diri dari sekarang!
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            class="inline-flex items-center justify-center border-3 border-black bg-white px-4 py-2 text-sm font-extrabold shadow-neo-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none"
            href="https://ikuttes.my.id/?view=DRILLS"
          >
            Latihan Soal Harian
          </a>
          <a
            class="inline-flex items-center justify-center border-3 border-black bg-black text-white px-4 py-2 text-sm font-extrabold shadow-neo-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none"
            href="https://ikuttes.my.id/?view=TRYOUT"
          >
            Simulasi CAT
          </a>
        </div>
      </section>
    </article>
  </Shell>
</ArticleLayout>
