---
// TEAM_030: Education level formasi page (/blog/formasi/untuk-:education/)
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import Shell from '../../../components/global/Shell.astro';
import ContentBlocks from '../../../components/article/ContentBlocks.astro';
import CtaCard from '../../../components/global/CtaCard.astro';

import { getRuntimeEnv } from '../../../lib/utils/runtime';
import { getDb } from '../../../lib/db/client';
import {
  getFormasiPageBySlug,
  getAllFormasiInstitutions,
} from '../../../lib/db/queries';

import {
  buildSiteSchema,
  buildOrganizationSchema,
  buildBreadcrumbSchema,
  buildWebPageSchema,
  normalizeSeoConfig,
} from '../../../lib/utils/seo';

import { injectCtaBlock } from '../../../lib/blogContent';
import { setCacheControl, PROGRAMMATIC_CACHE_CONTROL, NOT_FOUND_CACHE_CONTROL } from '../../../lib/utils/cache';

const { education } = Astro.params;

if (!education) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
  return new Response('Not found', { status: 404 });
}

const env = getRuntimeEnv(Astro.locals);
const db = getDb(env);

const pageSlug = `untuk-${education}`;
const page = await getFormasiPageBySlug(db, pageSlug);

if (!page || page.pageType !== 'education') {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
  return new Response('Not found', { status: 404 });
}

setCacheControl(Astro.response.headers, PROGRAMMATIC_CACHE_CONTROL);

const canonicalPath = `/formasi/untuk-${education}`;

const blocks = injectCtaBlock(page.contentBlocks, 'practice');

const seo = normalizeSeoConfig({
  title: page.title,
  description: page.metaDescription,
  canonicalPath,
  noindex: false,
  ogType: 'article',
});

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Formasi CPNS', path: '/formasi' },
    { name: page.educationLevel ?? education, path: canonicalPath },
  ]),
  buildWebPageSchema({ title: seo.title, description: seo.description ?? null, path: canonicalPath }),
].filter(Boolean);

// Get institutions for related links
const institutions = await getAllFormasiInstitutions(db);
---

<ArticleLayout
  title={seo.title}
  description={seo.description ?? null}
  canonical={seo.canonical}
  noindex={seo.noindex}
  schema={schema}
>
  <Shell>
    <article class="grid gap-6">
      <header class="border-3 border-black bg-white p-6 shadow-neo">
        <div class="text-xs font-black uppercase tracking-wider text-brand-lime">FORMasi BY PENDIDIKAN</div>
        <h1 class="mt-2 text-2xl font-extrabold">{page.title}</h1>
        {seo.description ? <p class="mt-3 text-sm text-black/80">{seo.description}</p> : null}
        {page.hasPlaceholderData ? (
          <p class="mt-2 text-xs text-yellow-600 bg-yellow-50 border border-yellow-200 rounded px-2 py-1 inline-block">
            Data formasi akan segera diperbarui dengan informasi terkini.
          </p>
        ) : null}
      </header>

      <ContentBlocks blocks={blocks} />

      {institutions.length > 0 && (
        <section class="border-3 border-black bg-white p-6 shadow-neo-sm">
          <h2 class="text-lg font-extrabold">Instansi yang Menerima {page.educationLevel}</h2>
          <p class="mt-2 text-sm text-black/70">Cek formasi instansi favorit:</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {institutions.map((inst) => (
              <a
                href={`/blog/formasi/${inst.institutionSlug}`}
                class="inline-block border-2 border-black bg-white px-3 py-2 text-sm font-bold shadow-neo-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none hover:bg-brand-lime/10 transition-all"
              >
                {inst.institution}
              </a>
            ))}
          </div>
        </section>
      )}

      <CtaCard style="hard" />

      <section class="border-3 border-black bg-white p-6 shadow-neo-sm">
        <h2 class="text-lg font-extrabold">Latihan Soal SKD untuk {page.educationLevel}</h2>
        <p class="mt-2 text-sm text-black/80">Persiapkan tes kompetensi dasar dengan latihan:</p>
        <div class="mt-4">
          <a
            class="inline-flex items-center justify-center border-3 border-black bg-brand-lime px-4 py-2 text-sm font-extrabold shadow-neo-sm hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none"
            href="https://ikuttes.my.id/"
          >
            Mulai Latihan Sekarang
          </a>
        </div>
      </section>
    </article>
  </Shell>
</ArticleLayout>
