---
// TEAM_033: Formasi category hub page - Design System Refactor
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import Shell from '../../../components/global/Shell.astro';
import HubLinks from '../../../components/hub/HubLinks.astro';
import Card from '../../../components/global/Card.astro';
import Breadcrumbs from '../../../components/global/Breadcrumbs.astro';

import { getRuntimeEnv } from '../../../lib/utils/runtime';
import { getDb } from '../../../lib/db/client';
import { getHubBySlug, getProgrammaticPagesByHub } from '../../../lib/db/queries';

import {
  buildSiteSchema,
  buildOrganizationSchema,
  buildBreadcrumbSchema,
  buildWebPageSchema,
  normalizeSeoConfig,
} from '../../../lib/utils/seo';

import { setCacheControl, PROGRAMMATIC_CACHE_CONTROL, NOT_FOUND_CACHE_CONTROL } from '../../../lib/utils/cache';

// Valid formasi categories
const VALID_CATEGORIES = ['provinsi', 'kota', 'institusi', 'pendidikan'] as const;
type Category = typeof VALID_CATEGORIES[number];

const category = Astro.params.category as Category;

// Validate category
if (!category || !VALID_CATEGORIES.includes(category)) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
}

const env = getRuntimeEnv(Astro.locals);
const db = getDb(env);

// Fetch hub data
const hubRecord = category ? await getHubBySlug(db, category) : null;

if (category && !hubRecord) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
  setCacheControl(Astro.response.headers, NOT_FOUND_CACHE_CONTROL);
}

// Fetch all pages in this category
const pages = hubRecord ? await getProgrammaticPagesByHub(db, category, 100) : [];

// Map to HubLinks format
const hubItems = pages.map((page) => ({
  href: `/blog/formasi/${category}/${page.slug}`,
  title: page.title,
  updatedAt: page.updatedAt ? new Date(page.updatedAt).toISOString().slice(0, 10) : null,
}));

// SEO
const canonicalPath = `/formasi/${category}`;
const seo = normalizeSeoConfig({
  title: hubRecord?.title ?? 'Formasi CPNS',
  description: hubRecord?.metaDescription ?? null,
  canonicalPath,
  noindex: false,
  ogType: 'website',
});

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Ikuttes Blog', path: '/' },
    { name: 'Formasi CPNS', path: '/formasi' },
    { name: hubRecord?.title ?? category ?? '', path: canonicalPath },
  ]),
  buildWebPageSchema({ title: seo.title, description: seo.description ?? null, path: canonicalPath }),
].filter(Boolean);

setCacheControl(Astro.response.headers, PROGRAMMATIC_CACHE_CONTROL);
---

<ArticleLayout
  title={seo.title}
  description={seo.description ?? null}
  canonical={seo.canonical}
  noindex={seo.noindex}
  schema={schema}
>
  <Shell>
    <Breadcrumbs items={[
      { name: 'Ikuttes Blog', path: '/' },
      { name: 'Formasi CPNS', path: '/formasi' },
      { name: hubRecord?.title ?? category ?? '', path: canonicalPath },
    ]} />

    <div class="space-y-8">
      {/* Header */}
      <header class="bg-white rounded-lg border border-border p-6 md:p-8">
        <div class="inline-block px-3 py-1 rounded-md bg-tiu/20 text-caption font-medium uppercase tracking-wider mb-4">
          Formasi CPNS 2024
        </div>
        <h1 class="text-heading-1 text-text mb-4">{hubRecord?.title ?? category}</h1>
        {hubRecord?.introduction && (
          <p class="text-body text-text-secondary leading-relaxed mb-3">{hubRecord.introduction}</p>
        )}
        <p class="text-body-sm text-text-muted">
          Total {pages.length} halaman tersedia
        </p>
      </header>

      {/* Hub Links */}
      <section>
        <h2 class="text-heading-3 text-text mb-5">Pilih {hubRecord?.title ?? category}</h2>
        <HubLinks items={hubItems} />
      </section>

      {/* SKD CTA */}
      <section class="bg-tiu/10 rounded-xl p-6 md:p-8 border border-tiu/20">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
          <div>
            <h2 class="text-heading-3 text-text mb-2">Siap Hadapi SKD?</h2>
            <p class="text-body text-text-secondary">
              Setelah lolos administrasi, ujian SKD adalah tahapan berikutnya. Persiapkan diri dari sekarang!
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://ikuttes.my.id/?view=DRILLS"
              class="inline-flex items-center justify-center px-5 py-2.5 bg-secondary text-text font-medium rounded-md hover:bg-secondary-hover transition-colors"
            >
              Latihan Soal Harian
            </a>
            <a
              href="https://ikuttes.my.id/?view=TRYOUT"
              class="inline-flex items-center justify-center px-5 py-2.5 bg-primary text-text-inverted font-medium rounded-md hover:bg-primary-hover transition-colors"
            >
              Simulasi CAT
            </a>
          </div>
        </div>
      </section>

      {/* CTA Card - Warm Cream */}
      <Card
        variant="cream"
        size="lg"
        href="https://ikuttes.my.id/"
        icon="🎯"
        eyebrow="Selanjutnya"
        title="Persiapkan Diri untuk CPNS"
        description="Setelah cek formasi, mulai latihan soal sekarang. Daily Quiz gratis dengan pembahasan lengkap."
        buttonLabel="Mulai Latihan →"
        external
      />
    </div>
  </Shell>
</ArticleLayout>
