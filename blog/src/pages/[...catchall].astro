---
// TEAM_010: catch-all 404 page
import HubLayout from '../layouts/HubLayout.astro';
import Shell from '../components/global/Shell.astro';
import { buildCanonicalUrl, buildBreadcrumbSchema, buildOrganizationSchema, buildSiteSchema, buildWebPageSchema } from '../lib/utils/seo';

Astro.response.status = 404;
Astro.response.statusText = 'Not found';

const canonical = buildCanonicalUrl(Astro.url.pathname);
const title = 'Halaman tidak ditemukan';
const description = 'Halaman yang kamu cari tidak tersedia.';

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([{ name: 'Ikuttes Blog', path: '/' }]),
  buildWebPageSchema({ title, description, path: Astro.url.pathname }),
];
---

<HubLayout title={title} description={description} canonical={canonical} noindex={true} schema={schema}>
  <Shell>
    <div class="border-3 border-black bg-white p-6 shadow-neo">
      <h1 class="text-2xl font-extrabold">404</h1>
      <p class="mt-3 text-sm text-black/80">Halaman ini tidak ada. Coba kembali ke hub:</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a class="border-3 border-black bg-brand-lime px-4 py-2 text-sm font-extrabold shadow-neo-sm" href="/blog/tiu">TIU</a>
        <a class="border-3 border-black bg-brand-pink px-4 py-2 text-sm font-extrabold shadow-neo-sm" href="/blog/twk">TWK</a>
        <a class="border-3 border-black bg-brand-purple px-4 py-2 text-sm font-extrabold shadow-neo-sm" href="/blog/tkp">TKP</a>
      </div>
    </div>
  </Shell>
</HubLayout>
