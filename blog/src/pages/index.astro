---
// TEAM_033: Blog Home - Design System Refactor
import HubLayout from '../layouts/HubLayout.astro';
import Shell from '../components/global/Shell.astro';
import Card from '../components/global/Card.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';
import { buildCanonicalUrl, buildCollectionPageSchema, buildOrganizationSchema, buildSiteSchema, buildBreadcrumbSchema } from '../lib/utils/seo';
import { setCacheControl, HUB_CACHE_CONTROL } from '../lib/utils/cache';

setCacheControl(Astro.response.headers, HUB_CACHE_CONTROL);

const canonical = buildCanonicalUrl('/');
const title = 'Ikuttes Blog — CPNS TIU, TWK, TKP';
const description = 'Panduan CPNS yang langsung mengarah ke latihan harian: TIU, TWK, dan TKP.';

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Beranda', path: '/' },
    { name: 'Blog', path: '/blog' }
  ]),
  buildCollectionPageSchema({ title, description, path: '/' }),
];
---

<HubLayout title={title} description={description} canonical={canonical} schema={schema}>
  <Shell>
    <Breadcrumbs items={[
      { name: 'Beranda', path: '/' },
      { name: 'Blog', path: '/blog' }
    ]} />

    <div class="space-y-10">
      {/* Hero Section */}
      <section class="text-center py-8 md:py-12">
        <h1 class="text-3xl md:text-4xl font-bold text-stone-800 mb-4 leading-tight">
          Belajar CPNS, langsung ke latihan
        </h1>
        <p class="text-lg text-stone-600 max-w-2xl mx-auto mb-6 leading-relaxed">
          Pilih materi di bawah, baca ringkasnya, lalu kerjakan Daily Quiz di Ikuttes.
        </p>
        <p class="text-sm text-stone-500">
          Terakhir diperbarui: {new Date().toLocaleDateString('id-ID', { month: 'long', year: 'numeric' })}
        </p>
      </section>

      {/* Hub Cards - Playful Pastel */}
      <section class="grid gap-4 sm:grid-cols-3">
        <Card
          variant="lavender"
          size="lg"
          href="/blog/tiu"
          icon="🧠"
          eyebrow="Materi"
          title="TIU"
          description="Tes Intelegensi Umum: verbal, numerik, dan logika analitis."
        />
        <Card
          variant="peach"
          size="lg"
          href="/blog/twk"
          icon="🇮🇩"
          eyebrow="Materi"
          title="TWK"
          description="Tes Wawasan Kebangsaan: Pancasila, UUD 1945, NKRI, Bhinneka."
        />
        <Card
          variant="mint"
          size="lg"
          href="/blog/tkp"
          icon="🌟"
          eyebrow="Materi"
          title="TKP"
          description="Tes Karakteristik Pribadi: soal situasional berbobot."
        />
      </section>

      {/* Formasi CTA - Neo-playful Card */}
      <Card
        variant="sky"
        size="lg"
        href="/blog/formasi"
        icon="📋"
        eyebrow="Informasi"
        title="Formasi CPNS 2024"
        description="Cek formasi lengkap berdasarkan provinsi, instansi, dan pendidikan. Data terbaru untuk persiapan pendaftaran."
        buttonLabel="Lihat Semua Formasi →"
      />

      {/* Content Section */}
      <section class="bg-white rounded-[28px] border-2 border-stone-200 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-stone-800 mb-4 leading-tight">Panduan Lengkap Persiapan CPNS</h2>
        <p class="text-base text-stone-600 leading-relaxed mb-8">
          Ikuttes Blog menyediakan materi persiapan CPNS yang terstruktur untuk membantu kamu meraih skor terbaik. Dengan fokus pada tiga kategori utama yaitu TIU, TWK, dan TKP, kami memberikan latihan soal harian dan pembahasan sesuai kisi-kisi resmi Kementerian PANRB.
        </p>

        <h3 class="text-xl font-semibold text-stone-800 mb-4 leading-snug">Tiga Kategori Materi yang Diujikan</h3>

        <div class="space-y-6 mb-8">
          <div class="border-l-4 border-indigo-300 pl-4">
            <h4 class="text-lg font-semibold text-stone-800 mb-2 leading-snug">TIU (Tes Intelegensi Umum)</h4>
            <p class="text-base text-stone-600 leading-relaxed">
              Menguji kemampuan verbal, numerik, dan logika analitis. Soal meliputi analogi, silogisme, deret angka, dan soal cerita. Strategi terbaik adalah latihan rutin setiap hari.
            </p>
          </div>

          <div class="border-l-4 border-orange-300 pl-4">
            <h4 class="text-lg font-semibold text-stone-800 mb-2 leading-snug">TWK (Tes Wawasan Kebangsaan)</h4>
            <p class="text-base text-stone-600 leading-relaxed">
              Menguji pemahaman empat pilar kebangsaan: Pancasila, UUD 1945, NKRI, dan Bhinneka Tunggal Ika. Mencakup sejarah, ketatanegaraan, dan nilai-nilai nasionalisme.
            </p>
          </div>

          <div class="border-l-4 border-emerald-300 pl-4">
            <h4 class="text-lg font-semibold text-stone-800 mb-2 leading-snug">TKP (Tes Karakteristik Pribadi)</h4>
            <p class="text-base text-stone-600 leading-relaxed">
              Menilai kepribadian dan manajemen dalam situasi kerja. Soal studi kasus dengan pilihan berbobot 1-5. Fokus pada pelayanan publik dan kerjasama tim.
            </p>
          </div>
        </div>

        <h3 class="text-xl font-semibold text-stone-800 mb-4 leading-snug">Cara Menggunakan Ikuttes Blog</h3>
        <p class="text-base text-stone-600 leading-relaxed">
          Pilih materi sesuai kebutuhan belajar, baca ringkasan, dan langsung praktikkan dengan soal latihan. Kami merekomendasikan minimal 30 menit latihan setiap hari untuk hasil optimal.
        </p>
      </section>

      {/* Stats Section - Playful Cards */}
      <section class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <Card
          variant="rose"
          size="stat"
          stat="10.000+"
          statLabel="Peserta Terbantu"
          title=""
        />
        <Card
          variant="sky"
          size="stat"
          stat="2.500+"
          statLabel="Soal Latihan"
          title=""
        />
        <Card
          variant="lavender"
          size="stat"
          stat="50.000+"
          statLabel="Tryout Dikerjakan"
          title=""
        />
        <Card
          variant="mint"
          size="stat"
          stat="100%"
          statLabel="Gratis Selamanya"
          title=""
        />
      </section>

      {/* CTA Card - Warm Cream */}
      <Card
        variant="cream"
        size="lg"
        href="https://ikuttes.my.id/"
        icon="🚀"
        eyebrow="Ayo Mulai"
        title="Mulai Latihan Sekarang"
        description="Akses ribuan soal latihan CPNS dengan pembahasan lengkap. TIU, TWK, TKP — semua ada!"
        buttonLabel="Buka Daily Quiz →"
        external
      />
    </div>
  </Shell>
</HubLayout>
