---
// TEAM_010: hub page (/:hub)
// TEAM_017: legacy hub route is intentionally disabled (hub listings moved to /blog/h/:hub)
// We keep this route as a prerendered static 404 for the known hubs to avoid SSR dynamic route conflicts.

import HubLayout from '../../layouts/HubLayout.astro';
import Shell from '../../components/global/Shell.astro';
import { HUB_SLUGS } from '../../lib/constants';
import {
  buildBreadcrumbSchema,
  buildCanonicalUrl,
  buildOrganizationSchema,
  buildSiteSchema,
  buildWebPageSchema,
} from '../../lib/utils/seo';

export const prerender = true;
export const getStaticPaths = async () => HUB_SLUGS.map((hub) => ({ params: { hub } }));

Astro.response.status = 404;
Astro.response.statusText = 'Not found';

const hub = Astro.params.hub;
const canonical = buildCanonicalUrl(Astro.url.pathname);
const title = 'Halaman tidak ditemukan';
const description = 'Halaman yang kamu cari tidak tersedia.';

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([{ name: 'Ikuttes Blog', path: '/' }]),
  buildWebPageSchema({ title, description, path: Astro.url.pathname }),
];
---
<HubLayout title={title} description={description} canonical={canonical} noindex={true} schema={schema}>
  <Shell>
    <div class="border-3 border-black bg-white p-6 shadow-neo">
      <h1 class="text-2xl font-extrabold">404</h1>
      <p class="mt-3 text-sm text-black/80">
        Halaman hub <span class="font-mono font-semibold">{hub}</span> tidak tersedia. Gunakan hub baru:
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        {HUB_SLUGS.map((value) => (
          <a
            class="border-3 border-black bg-white px-4 py-2 text-sm font-extrabold shadow-neo-sm"
            href={`/blog/h/${value}`}
          >
            {value.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </Shell>
</HubLayout>
