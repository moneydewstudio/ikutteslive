---
// TEAM_010: hub page (/:hub)
import HubLayout from '../../layouts/HubLayout.astro';
import Shell from '../../components/global/Shell.astro';
import CtaCard from '../../components/global/CtaCard.astro';
import HubLinks from '../../components/hub/HubLinks.astro';

import { getRuntimeEnv } from '../../lib/utils/runtime';
import { getDb } from '../../lib/db/client';
import { getHubBySlug, getRecentProgrammaticPagesForHub } from '../../lib/db/queries';
import { buildBreadcrumbSchema, buildCanonicalUrl, buildCollectionPageSchema, buildOrganizationSchema, buildSiteSchema } from '../../lib/utils/seo';
import { setCacheControl, HUB_CACHE_CONTROL } from '../../lib/utils/cache';

setCacheControl(Astro.response.headers, HUB_CACHE_CONTROL);

const hub = Astro.params.hub;
if (!hub) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
}

const env = getRuntimeEnv(Astro.locals);
const db = getDb(env);
const hubRecord = hub ? await getHubBySlug(db, hub) : null;

if (!hubRecord) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not found';
}

const canonicalPath = hubRecord ? `/${hubRecord.slug}` : Astro.url.pathname;
const canonical = buildCanonicalUrl(canonicalPath);

const title = hubRecord ? hubRecord.title : 'Hub';
const description = hubRecord?.metaDescription ?? null;

const schema = [
  buildSiteSchema(),
  buildOrganizationSchema(),
  buildBreadcrumbSchema([
    { name: 'Ikuttes Blog', path: '/' },
    { name: (hubRecord?.slug ?? hub ?? '').toUpperCase(), path: canonicalPath },
  ]),
  buildCollectionPageSchema({
    title,
    description,
    path: canonicalPath,
  }),
];

const recent = hubRecord
  ? await getRecentProgrammaticPagesForHub(db, hubRecord.slug, 12)
  : [];

const items = recent.map((row) => ({
  href: `/${row.hub}/${row.slug}`,
  title: row.title,
  updatedAt: row.updatedAt ? new Date(row.updatedAt).toISOString().slice(0, 10) : null,
}));
---

<HubLayout title={title} description={description} canonical={canonical} schema={schema}>
  <Shell>
    <div class="grid gap-8">
      <section class="border-3 border-black bg-white p-6 shadow-neo">
        <h1 class="text-2xl font-extrabold">{title}</h1>
        {hubRecord?.introduction ? (
          <p class="mt-3 text-sm text-black/80">{hubRecord.introduction}</p>
        ) : null}
      </section>

      <CtaCard style="hard" />

      <section>
        <h2 class="text-lg font-extrabold">Artikel terbaru</h2>
        <p class="mt-2 text-sm text-black/70">
          Pilih materi lalu langsung latihan di Daily Quiz.
        </p>
        <div class="mt-5">
          <HubLinks items={items} />
        </div>
      </section>
    </div>
  </Shell>
</HubLayout>
