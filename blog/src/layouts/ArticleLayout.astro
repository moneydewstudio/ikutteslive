---
// TEAM_010: article layout wrapper
import BaseLayout from './BaseLayout.astro';

type Props = {
  title: string;
  description?: string | null;
  canonical: string;
  noindex?: boolean;
  schema?: unknown[];
};

const { title, description = null, canonical, noindex = false, schema = [] } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  ogType="article"
  schema={schema}
>
  <slot />
</BaseLayout>
